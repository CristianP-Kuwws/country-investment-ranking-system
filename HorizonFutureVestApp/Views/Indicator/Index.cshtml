@model List<IndicatorViewModel>
@{
    ViewData["Title"] = "Indicator Page";
}

<div class="row">
    <div class="text-center">
        <h1 class="display-4">Indicadores por pais</h1>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12 col-md-3">
        <a class="btn btn-outline-success" asp-controller="Indicator" asp-action="Create">Crear Indicador</a>

    </div>

</div>

<div class="row mt-2">
    @if (Model.Count == 0)
    {
        <div class="text-center">
            <h4 class="display-4">No existen Indicadores creados.</h4>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            <div class="row mt-4">
                <div class="col-12 col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@item.CountryName</h5> 
                            <p class="card-text">
                                MacroIndicador: @item.MacroIndicatorName <br /> 
                                Valor: @item.Value <br />
                                Año: @item.Year <br />
                            </p>
                            <div class="mt-2">
                                <a class="btn btn-outline-danger float-end" asp-controller="Indicator" asp-action="Delete" asp-route-id="@item.IdIndicator">Borrar</a>
                                <a class="btn btn-outline-warning float-end me-2" asp-controller="Indicator" asp-action="Edit" asp-route-id="@item.IdIndicator">Editar</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

</div>