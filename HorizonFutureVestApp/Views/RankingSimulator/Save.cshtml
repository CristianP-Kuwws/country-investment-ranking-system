@model SaveSimulationMacroViewModel
@{
    bool editMode = ViewBag.EditMode ?? false;
    ViewData["Title"] = editMode ? "Editar MacroIndicador" : "Agregar MacroIndicador";
}

<div class="col-12 col-md-6 offset-md-3">
    <div class="card">
        <div class="card-header bg-success text-light">
            <h5 class="text-center">@ViewData["Title"]</h5>
        </div>
        <div class="card-body">

            <form asp-action="@(editMode ? "Edit" : "Add")" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="IdMacroIndicator" />
                <input type="hidden" asp-for="Name" value="" />

                @if (!editMode)
                {

                    <div class="mb-3">
                        <label asp-for="SelectedMacroIndicator" class="form-label">MacroIndicador</label>
                        <select asp-for="SelectedMacroIndicator"
                                class="form-select"
                                asp-items="@(new SelectList(Model.AvailableMacros, "IdOption", "Name"))">
                            <option value="">-- Seleccione --</option>
                        </select>
                        <span asp-validation-for="SelectedMacroIndicator" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">MacroIndicador</label>
                        <input type="text" class="form-control" value="@Model.Name" readonly />
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Weight" class="form-label">
                        Peso (Disponible: @Model.RemainingWeight.ToString("F4"))
                    </label>
                    <input asp-for="Weight" class="form-control" step="0.0001" />
                    <span asp-validation-for="Weight" class="text-danger"></span>
                </div>

                <div>
                    <button type="submit" class="btn btn-outline-primary float-end">Guardar</button>
                    <a asp-action="Index" class="btn btn-outline-warning float-end me-2">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
