@model Application.ViewModels.RankingSimulator.ResultsViewModels.RankingResultsViewModel
@{
    ViewData["Title"] = "Simulator Results";
}

<div class="row">
    <div class="text-center">
        <h1 class="display-4">Resultados de Simulacion (@Model.Year)</h1>
    </div>
</div>

@if (!Model.Rankings.Any())
{
    <div class="alert alert-warning mt-4">
        No hay suficiente paises para poder calcular la simulacion del ranking y la tasa de retorno.
        El unico pais que cumple con los requisitos es <strong>@Model.SingleCountryName</strong>.
        Debe agregar mas indicadores a los demas paises en el año seleccionado.
        <a asp-controller="Indicator" asp-action="Index">Ir al mantenimiento de indicadores</a>
    </div>
}
else
{
    <table class="table table-bordered table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>Posicion</th>
                <th>Pais</th>
                <th>Codigo ISO</th>
                <th>Scoring</th>
                <th>Tasa de Retorno Estimada</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Rankings)
            {
                <tr>
                    <td>@item.Position</td>
                    <td>@item.CountryName</td>
                    <td>@item.IsoCode</td>
                    <td>@item.Scoring.ToString("F4")</td>
                    <td>@item.EstimatedReturnRate.ToString("P2")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="row mt-3">
    <div class="col-12 text-center">
        <a asp-controller="RankingSimulator" asp-action="Index" class="btn btn-outline-secondary">
            Volver Atrás
        </a>
    </div>
</div>


